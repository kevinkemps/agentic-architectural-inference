OPENAI_API_KEY=sk-proj-xxxx
OPENAI_MODEL=gpt-4o

# Anthropic Claude (set LLM_PROVIDER=claude to use)
ANTHROPIC_API_KEY=sk-ant-xxxx
ANTHROPIC_MODEL=claude-sonnet-4-5

# Toggle this to 'static' to skip the LLM for the first step
FIRST_AGENT_MODE=llm

# Options: local | local-ollama | claude | openai
LLM_PROVIDER=local

# Model name for local-ollama provider
MODEL_NAME=qwen3-vl:8b
